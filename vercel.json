{\n  "version": 2,\n  "builds": [\n    {\n      "src": "server/server.js",\n      "use": "@vercel/node"\n    },\n    {\n      "src": "public/**",\n      "use": "@vercel/static"\n    }\n  ],\n  "routes": [\n    {\n      "src": "/api/(.*)",\n      "dest": "server/server.js"\n    },\n    {\n      "src": "/(.*)",\n      "dest": "public/$1"\n    }\n  ],\n  "env": {\n    "CLASH_API_TOKEN": "@clash_api_token"\n  }\n}\n